# Company A — Microsoft Graph API (device flow)
COMPANYA_TENANT_ID=your-tenant-id
COMPANYA_CLIENT_ID=your-client-id
COMPANYA_EMAIL=me@companya.com

# Company B — Microsoft Graph API (device flow)
# If Company B shares the same Azure tenant as Company A,
# reuse the same TENANT_ID and CLIENT_ID — tokens are cached per company.
COMPANYB_TENANT_ID=your-tenant-id
COMPANYB_CLIENT_ID=your-client-id
COMPANYB_EMAIL=me@companyb.com

# Add additional accounts following the same pattern:
# COMPANYID_TENANT_ID=
# COMPANYID_CLIENT_ID=
# COMPANYID_EMAIL=

# --- Gmail API (future: for fetch-gmail.js fallback connector) ---
# Not needed if using MCP Gmail tools.
# PERSONAL_GMAIL_CLIENT_ID=your-gmail-client-id
# PERSONAL_GMAIL_CLIENT_SECRET=your-gmail-client-secret
# PERSONAL_GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# Gmail API — for deletion script (get from Google Cloud Console)
GMAIL_CLIENT_ID=your-client-id
GMAIL_CLIENT_SECRET=your-client-secret
# Refresh token is stored automatically in data/.gmail-token-cache.json after first auth
